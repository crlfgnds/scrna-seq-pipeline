/*
 * HPC profile — run on a cluster using Singularity + a job scheduler.
 * Activated by: -profile hpc
 * NOTE: queue name and resources are cluster-specific — adjust for your system.
 */

singularity.enabled    = true
singularity.autoMounts = true

process {
    executor = 'slurm'      // change to 'pbs', 'sge', etc. if your cluster differs
    queue    = 'normal'     // partition name — ask your cluster admin
    cpus     = 8
    memory   = '64 GB'
    time     = '24h'
}
