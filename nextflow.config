/*
 * Pipeline parameters — set default values for the less critical ones, can always be overridden
 * All the args from all the R scripts
 * Overridden by: --param value on CLI, or -params-file
 */
params {
      // --- input ---
      input            = null
      batch            = null
      h5_file          = null
      rds_file         = null
      sample_name      = null
  
      // --- QC ---
      mito_thresh      = 0.05
      min_features     = 200
      max_features     = 6000
      min_counts       = 500
      max_counts       = 30000

      // --- HTO demux ---
      hto_h5           = null
      hashtags         = null
      hashtag_labels   = null
      group_pattern    = null

      // --- normalization ---
      n_features       = 2000

      // --- integration ---
      integration_features = 2000
      integration_method  = "cca"
      split_by         = "experiment"

      // --- clustering ---
      n_dims           = 17
      resolution       = 0.5
      n_neighbors      = 150
      min_dist         = 0.4
      group_by_var     = null

      // --- annotation ---
      celltype_col     = "cell_type"
      marker_file      = null
      annotation_file  = null
      palette_arg      = "npg"
      top_n_genes      = 10
      // --- subset ---
      clusters              = null
      subset_name           = null
      experiment_col        = "experiment"
      experiments           = null
      subset_n_dims         = 10
      subset_resolution     = 0.3
      subset_palette_arg    = "npg"
      
      // --- DE ---
      group_col        = null
      ident1           = null
      ident2           = null
      min_pct          = 0.25
      logfc_thresh     = 0.25
      padj_cutoff      = 0.01
      volcano_xlim     = "auto"
      volcano_fc       = "auto"
      volcano_p        = "auto"
      whole_de_file    = null

      // --- GO ---
      ont             = "BP"
      n_top_terms     = 10
      min_gs_size     = 10
      max_gs_size     = 100
      score_type      = "pos"
      pvalue_cutoff   = 0.05
      direction       = "both"
  
      // --- composition ---
      sample_col       = null
      group_levels     = null
      time_col         = null
      time_levels      = null


      // --- pseudotime ---
      root_cluster     = null
  
      // --- cellchat ---
      source_cells     = null

      // --- organism ---
      organism         = null
  
      // --- optional modules ---
      hto              = false
      subset_recluster = false

      // --- downstream analysis toggles (PHASE4) ---
      run_de           = true
      run_composition  = true
      run_pseudotime   = true
      run_cellchat     = true

      // --- execution control ---
      step             = null        // which phase to run: phase1|cluster_only|phase2|phase3|phase4
      outdir           = "results"   // base folder where publishDir copies outputs
  }

/* Enable Docker or HPC accordingly.
* Both profiles point to the same container image - the one I built with Dockerfile. 
* Nextflow automatically converts the Docker image to Singularity format when running with the HPC profile.
*/
profiles{
    local {
        includeConfig 'conf/local.config'
    }
    hpc {
        includeConfig 'conf/hpc.config'
    }
}

// Add container name
process.container = 'crlfgnds/scrna-seq-pipeline:latest'

// Outputs are published per-module via publishDir, into ${params.outdir}/<subfolder>

//Add manifest for portfolio
  manifest {
      name        = 'scrna-seq-pipeline'
      author      = 'Anna Carolina Fagundes'
      description = 'Modular scRNA-seq analysis pipeline'
      version     = '1.0.0'
  }
  